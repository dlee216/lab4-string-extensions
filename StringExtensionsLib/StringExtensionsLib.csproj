<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>StringExtensionsLib</RootNamespace>
    <AssemblyName>StringExtensionsLib</AssemblyName>
    <PackageId>DoYoungLeeStringExtensions</PackageId>
    <Version>1.0.0</Version>
    <Authors>Do Young Lee</Authors>
    <Company>Centennial College</Company>
    <Description>String extension methods.</Description>
    <PackageTags>string;extensions;uppercase</PackageTags>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

</Project>
